{
	"compilerOptions": {
		"module": "nodenext",
		"declaration": true,
		"removeComments": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2024",
		"outDir": "./dist",
		"allowJs": true,
		"baseUrl": "./",
		"incremental": true,
		"esModuleInterop": true,
		"strict": true,
		"typeRoots": [
			"node_modules/@types",
			"src/@types"
		],
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules",
		"dist"
	]
}